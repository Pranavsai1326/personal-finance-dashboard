generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntryType {
  INCOME
  EXPENSE
}

enum FixedVariable {
  FIXED
  VARIABLE
}

enum Essentiality {
  ESSENTIAL
  NON_ESSENTIAL
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetStatus {
  UNDER_BUDGET
  NEAR_LIMIT
  OVER_BUDGET
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

model User {
  id                     String     @id @default(cuid())
  uid                    String     @unique
  email                  String     @unique
  name                   String
  phone                  String?
  role                   UserRole   @default(USER)
  status                 UserStatus @default(PENDING)
  passwordHash           String?
  mustChangePassword     Boolean    @default(false)
  mustSetup2FA           Boolean    @default(false)
  twoFactorEnabled       Boolean    @default(false)
  twoFactorSecret        String?
  twoFactorPendingSecret String?
  twoFactorBackupCodes   String[]   @default([])
  sessionVersion         Int        @default(0)
  resetOtpHash           String?
  resetOtpExpiry         DateTime?
  resetOtpAttempts       Int        @default(0)
  failedLoginAttempts    Int        @default(0)
  lockedUntil            DateTime?
  onboardedAt            DateTime?
  approvedAt             DateTime?
  approvedById           String?
  rejectedAt             DateTime?
  rejectionReason        String?
  lastLoginAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  categories     Category[]
  accounts       Account[]
  paymentMethods PaymentMethodType[]
  transactions   Transaction[]
  budgets        Budget[]
  investments    Investment[]
  bills          Bill[]
  goals          Goal[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  settings       AppSettings?
  profile        AppProfile?

  @@index([status])
}

model Category {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  type          EntryType
  subcategories Subcategory[]
  transactions  Transaction[]
  budgets       Budget[]
  createdAt     DateTime      @default(now())

  @@unique([userId, name])
}

model Subcategory {
  id         String       @id @default(cuid())
  name       String
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String
  transactions Transaction[]

  @@unique([categoryId, name])
}

model Account {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  name         String
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@unique([userId, name])
}

model PaymentMethodType {
  id           String        @id @default(cuid())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  name         String
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@unique([userId, name])
}

model Transaction {
  id             String         @id @default(cuid())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  date           DateTime
  description    String
  amount         Decimal        @db.Decimal(14, 2)
  type           EntryType
  category       Category       @relation(fields: [categoryId], references: [id])
  categoryId     String
  subcategory    Subcategory?   @relation(fields: [subcategoryId], references: [id])
  subcategoryId  String?
  merchant       String?
  account        Account?       @relation(fields: [accountId], references: [id])
  accountId      String?
  paymentMethodType   PaymentMethodType? @relation(fields: [paymentMethodTypeId], references: [id])
  paymentMethodTypeId String?
  location       String?
  tags           String[]       @default([])
  notes          String?
  recurring      Boolean        @default(false)
  fixedVariable  FixedVariable?
  essentiality   Essentiality?
  attachmentUrl  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([date])
  @@index([categoryId])
  @@index([type])
}

model Budget {
  id         String       @id @default(cuid())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  category   Category     @relation(fields: [categoryId], references: [id])
  categoryId String
  period     BudgetPeriod @default(MONTHLY)
  periodKey  String       // e.g. "2026-07" for monthly, "2026-Q2", "2026" for yearly
  amount     Decimal      @db.Decimal(14, 2)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([categoryId, period, periodKey])
}

model Investment {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  instrument         String
  category           String
  currentValue       Decimal  @db.Decimal(14, 2)
  monthlyContribution Decimal @db.Decimal(14, 2) @default(0)
  annualReturnPct    Decimal  @db.Decimal(5, 2)  @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model Bill {
  id            String    @id @default(cuid())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  name          String
  type          String
  dueDate       DateTime
  amount        Decimal   @db.Decimal(14, 2)
  paidAmount    Decimal   @db.Decimal(14, 2) @default(0)
  autoPay       Boolean   @default(false)
  interestRate  Decimal?  @db.Decimal(5, 2)
  tenureMonths  Int?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model Goal {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  name               String
  category           String
  targetAmount       Decimal  @db.Decimal(14, 2)
  currentAmount      Decimal  @db.Decimal(14, 2) @default(0)
  monthlyContribution Decimal @db.Decimal(14, 2) @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  event     String
  detail    String?
  ip        String?
  userAgent String?
  browser   String?
  os        String?
  device    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AppSettings {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
  data   Json   @default("{}")

  @@map("app_settings")
}

model AppProfile {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
  data   Json   @default("{}")

  @@map("app_profile")
}

model PlatformSettings {
  id                          String   @id @default("singleton")
  siteName                    String   @default("Penny Pilot")
  supportEmail                String?
  defaultSessionTimeoutMinutes Int     @default(30)
  minPasswordLength           Int      @default(8)
  require2FAForAdmins         Boolean  @default(false)
  updatedAt                   DateTime @updatedAt

  @@map("platform_settings")
}
